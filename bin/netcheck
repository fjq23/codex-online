#!/usr/bin/env bash
set -euo pipefail

show_header() {
  printf '\n== %s ==\n' "$1"
}

show_header "Context"
printf 'pwd=%s\n' "${PWD}"
printf 'user=%s\n' "$(id -un)"
printf 'codex=%s\n' "$(codex --version 2>/dev/null || echo 'not found')"

show_header "Proxy Env"
env | grep -Ei '^(http|https|all|no)_proxy=' | sort || echo "No proxy env found"

show_header "DNS"
getent hosts api.openai.com || true
getent hosts mihomo || true

show_header "Mihomo Controller"
if curl -fsS --max-time 5 http://mihomo:9090/version >/tmp/netcheck-mihomo-version.json 2>/dev/null; then
  cat /tmp/netcheck-mihomo-version.json
  printf '\n'
else
  echo "Cannot reach http://mihomo:9090/version"
fi

show_header "Mihomo Groups"
if curl -fsS --max-time 5 http://mihomo:9090/proxies >/tmp/netcheck-mihomo-proxies.json 2>/dev/null; then
  jq -r '
    [
      "Default=" + (.proxies.Default.now // "n/a"),
      "OpenAI=" + (.proxies.OpenAI.now // "n/a")
    ] | .[]
  ' /tmp/netcheck-mihomo-proxies.json
else
  echo "Cannot reach http://mihomo:9090/proxies"
fi

show_header "OpenAI Probe State"
if [ -f "${STATE_DIR}/openai-proxy-probe.state" ]; then
  cat "${STATE_DIR}/openai-proxy-probe.state"
else
  echo "No probe state yet"
fi

show_header "HTTP Reachability"
curl -I --max-time 12 https://api.openai.com/v1/models || true
printf '\n'
curl -I --max-time 12 https://platform.openai.com || true
printf '\n'
curl -I --max-time 12 https://chatgpt.com || true
printf '\n'
curl -I --max-time 10 https://registry.npmjs.org || true

show_header "Direct Without Proxy"
env -u HTTP_PROXY -u HTTPS_PROXY -u ALL_PROXY -u NO_PROXY \
    -u http_proxy -u https_proxy -u all_proxy -u no_proxy \
    curl -I --max-time 12 https://api.openai.com/v1/models || true

show_header "Codex Login"
codex login status || true

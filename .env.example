# Host bind ports. For public deployment, usually set these to 80 and 443.
HTTP_PORT=8080
HTTPS_PORT=8443

# Use :80 for plain HTTP on LAN/IP access. For public HTTPS, replace with your domain.
# Examples:
#   CADDY_SITE_ADDR=:80
#   CADDY_SITE_ADDR=codex.example.com
CADDY_SITE_ADDR=:80

# Generate with: ./scripts/hash-password.sh 'replace-this-password'
# Important: replace each `$` in the generated hash with `$$` before saving to `.env`.
BASIC_AUTH_USER=admin
BASIC_AUTH_HASH=REPLACE_WITH_CADDY_BCRYPT_HASH

# Match your Linux account UID/GID so uploaded and generated files are not root-owned.
APP_UID=1000
APP_GID=1000

TZ=Asia/Shanghai
TMUX_SESSION_PREFIX=ws
CODEX_VERSION=0.116.0

# Optional: set an API key if you do not want to log in interactively with `codex login`.
OPENAI_API_KEY=

# Optional runtime/build proxy variables for ttyd and Codex CLI.
# If you enable the Mihomo sidecar, these can stay empty because the override file sets them.
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=localhost,127.0.0.1,caddy,ttyd,filebrowser,mihomo

# Default resource limits. These defaults keep the whole stack at about 2G RAM:
#   ttyd 1536m + filebrowser 256m + caddy 128m + mihomo 128m = 2048m
TTYD_CPUS=1.25
TTYD_MEM_LIMIT=1536m
FILEBROWSER_CPUS=0.25
FILEBROWSER_MEM_LIMIT=256m
CADDY_CPUS=0.25
CADDY_MEM_LIMIT=128m
MIHOMO_CPUS=0.25
MIHOMO_MEM_LIMIT=128m

# Optional host ports for the Mihomo sidecar. Container-internal ports stay 7890/7891/9090.
MIHOMO_HTTP_PORT=17890
MIHOMO_SOCKS_PORT=17891
MIHOMO_API_PORT=19090
